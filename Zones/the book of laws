local fx_name = "CSI_ItemEdit"
local last_item = nil
local last_in = -1
local last_out = -1

function loop()
    -- We wrap the core logic in a function so if it fails, it doesn't crash the script
    local status, err = pcall(function()
        local track = reaper.GetSelectedTrack(0, 0)
        if track then
            local item = reaper.GetSelectedMediaItem(0, 0)
            
            if item and reaper.GetMediaItem_Track(item) == track then
                -- 1. Bulletproof check: Ensure plugin exists. If not, auto-add it!
                local fx_idx = reaper.TrackFX_GetByName(track, fx_name, false)
                if fx_idx < 0 then
                    fx_idx = reaper.TrackFX_AddByName(track, "JS:" .. fx_name, false, -1)
                    reaper.TrackFX_SetOpen(track, fx_idx, false) -- Keep the UI hidden
                end
                
                local item_len = reaper.GetMediaItemInfo_Value(item, "D_LENGTH")
                
                if item_len > 0 then
                    -- 2. Read the physical position of Fader 2 and Fader 6
                    local val_in = reaper.TrackFX_GetParamNormalized(track, fx_idx, 1) -- Slider 2
                    local val_out = reaper.TrackFX_GetParamNormalized(track, fx_idx, 5) -- Slider 6
                    
                    if item ~= last_item then
                        -- WE CLICKED A NEW ITEM: Sync the motors
                        local cur_in = reaper.GetMediaItemInfo_Value(item, "D_FADEINLEN")
                        local cur_out = reaper.GetMediaItemInfo_Value(item, "D_FADEOUTLEN")
                        
                        last_in = cur_in / item_len
                        last_out = cur_out / item_len
                        
                        reaper.TrackFX_SetParamNormalized(track, fx_idx, 1, last_in)
                        reaper.TrackFX_SetParamNormalized(track, fx_idx, 5, last_out)
                        last_item = item
                    else
                        -- WE ARE MOVING THE FADER: Update the item graphics
                        -- (Using math.abs prevents microscopic fader jitter from causing glitches)
                        if math.abs(val_in - last_in) > 0.001 then
                            local new_in = val_in * item_len
                            reaper.SetMediaItemInfo_Value(item, "D_FADEINLEN", new_in)
                            last_in = val_in
                            reaper.UpdateItemInProject(item) 
                        end
                        
                        if math.abs(val_out - last_out) > 0.001 then
                            local new_out = val_out * item_len
                            reaper.SetMediaItemInfo_Value(item, "D_FADEOUTLEN", new_out)
                            last_out = val_out
                            reaper.UpdateItemInProject(item)
                        end
                    end
                end
            else
                last_item = nil
            end
        end
    end)
    
    -- Keep script running constantly in the background even if a frame drops
    reaper.defer(loop) 
end

loop()

