`CSI_ItemFades_BackgroundEngine.lua`


-- =========================================================================
-- SCRIPT NAME: CSI_ItemFades_BackgroundEngine.lua
-- PURPOSE: Bridges selected item properties to the Monitor FX dummy plugin
-- to provide motorized fader feedback for the MCU Pro ItemFades zone.
-- =========================================================================

-- Target the Master Track
local master_track = reaper.GetMasterTrack(0)

-- 0x1000000 targets the global Monitor FX chain. 
-- The "+ 0" targets the VERY FIRST plugin in that chain. 
-- (If you place your dummy JSFX in the second slot, change this to "+ 1")
local monitor_fx_index = 0x1000000 + 0 

function loop()
    -- Get the currently selected media item
    local item = reaper.GetSelectedMediaItem(0, 0)
    
    if item then
        -- 1. Read the actual values from the selected item
        local item_pos = reaper.GetMediaItemInfo_Value(item, "D_POSITION")
        local item_len = reaper.GetMediaItemInfo_Value(item, "D_LENGTH")
        local fade_in = reaper.GetMediaItemInfo_Value(item, "D_FADEINLEN")
        local fade_out = reaper.GetMediaItemInfo_Value(item, "D_FADEOUTLEN")
        local vol = reaper.GetMediaItemInfo_Value(item, "D_VOL")
        
        -- 2. Normalize the values so the JSFX (and your faders) read them as 0.0 to 1.0.
        -- These "max" ranges dictate the scaling of your physical faders. 
        -- You can adjust these numbers to change the fader resolution.
        local max_fade = 10.0   -- Assumes 10 seconds is the maximum fade length you'd want on a fader
        local max_vol = 4.0     -- Approximately +12dB
        local max_time = 3600.0 -- Assumes 1 hour max project time for item start/end scaling
        
        local norm_start = math.min(item_pos / max_time, 1.0)
        local norm_fadein = math.min(fade_in / max_fade, 1.0)
        local norm_fadeout = math.min(fade_out / max_fade, 1.0)
        local norm_end = math.min((item_pos + item_len) / max_time, 1.0)
        local norm_vol = math.min(vol / max_vol, 1.0)

        -- 3. Check if a plugin actually exists in the targeted Monitor FX slot
        local is_valid_fx = reaper.TrackFX_GetFXName(master_track, monitor_fx_index, "")
        
        if is_valid_fx then
            -- 4. Write the normalized values to the dummy JSFX sliders.
            -- This forces the motorized faders on your MCU to snap to the correct positions automatically.
            -- Slider 0 = Fader 1 (Start)
            -- Slider 1 = Fader 2 (Fade In)
            -- Slider 5 = Fader 6 (Fade Out)
            -- Slider 6 = Fader 7 (End)
            -- Slider 7 = Fader 8 (Volume)
            reaper.TrackFX_SetParamNormalized(master_track, monitor_fx_index, 0, norm_start)
            reaper.TrackFX_SetParamNormalized(master_track, monitor_fx_index, 1, norm_fadein)
            reaper.TrackFX_SetParamNormalized(master_track, monitor_fx_index, 5, norm_fadeout)
            reaper.TrackFX_SetParamNormalized(master_track, monitor_fx_index, 6, norm_end)
            reaper.TrackFX_SetParamNormalized(master_track, monitor_fx_index, 7, norm_vol)
        end
    end

    -- Constantly loop this function in the background (prevents undo block spam)
    reaper.defer(loop)
end

-- Start the background loop
loop()


