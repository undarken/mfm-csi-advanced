-- @description Zoom In horizontally, change grid relatively
-- @version 1.8_IN

function main()
  local zoom_adjust = 0.5  -- Positive for Zoom In
  
  -- The exact pixel boundaries for each of the 15 grid divisions
  local stages = { 
      0,       -- [1] Threshold for 1/1
      80,      -- [2] Threshold for 1/2
      140,     -- [3] Threshold for 1/3
      200,     -- [4] Threshold for 1/4
      270,     -- [5] Threshold for 1/5  (NEW)
      350,     -- [6] Threshold for 1/6
      450,     -- [7] Threshold for 1/7  (NEW)
      560,     -- [8] Threshold for 1/8
      680,     -- [9] Threshold for 1/9
      820,     -- [10] Threshold for 1/10 (NEW)
      1000,    -- [11] Threshold for 1/12
      1400,    -- [12] Threshold for 1/16
      2400,    -- [13] Threshold for 1/32
      4500,    -- [14] Threshold for 1/64
      8000,    -- [15] Threshold for 1/128
      20000    -- [16] Upper Bound
  }
  
  -- The exactly matched 15 grid divisions
  local grid_t = { 1, 1/2, 1/3, 1/4, 1/5, 1/6, 1/7, 1/8, 1/9, 1/10, 1/12, 1/16, 1/32, 1/64, 1/128 }
            
  -- Force Zoom In
  reaper.adjustZoom(zoom_adjust, 0, true, -1)
  
  local zoom_lev = reaper.GetHZoomLevel()   
  
  for i = 1, #stages-1 do
    if zoom_lev > stages[i] and zoom_lev <= stages[i+1] then
      reaper.SetProjectGrid( 0, grid_t[i] )    
      break
    end
  end
end
  
main()


