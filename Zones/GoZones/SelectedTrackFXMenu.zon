        Option+Zoom+Control+Increase+JogWheel    Reaper  41180                                                                    // Envelopes: Move selected points up   1DB
                                                          
        /Option+Zoom+Decrease+JogWheel            Reaper _WOL_SETSELENVHMAX                                                        // SWS/wol: Set selected envelope height to maximum    
        Option+Zoom+Decrease+JogWheel            Reaper  41181                                                                    // Envelopes: Move selected points down 1DB
        /Option+Zoom+Increase+JogWheel            Reaper _WOL_SETSELENVHMAX                                                        // SWS/wol: Set selected envelope height to maximum
        Option+Zoom+Increase+JogWheel            Reaper  41180                                                                    // Envelopes: Move selected points up   1DB
                                      
       / Option+Decrease+JogWheel                 Reaper _WOL_SETSELENVHMAX                                                        // SWS/wol: Set selected envelope height to maximum 
        Option+Decrease+JogWheel                 Reaper  41181                                                                    // Envelopes: Move selected points down 1DB
        /Option+Increase+JogWheel                 Reaper _WOL_SETSELENVHMAX                                                        // SWS/wol: Set selected envelope height to maximum
        Option+Increase+JogWheel                 Reaper  41180                                                                    // Envelopes: Move selected points up   1DB
                              
                                      
        /Option+Scrub+Decrease+JogWheel           Reaper _WOL_SETSELENVHMAX                                                        // SWS/wol: Set selected envelope height to maximum  
        Option+Scrub+Decrease+JogWheel           Reaper  41181                                                                    // Envelopes: Move selected points down 1DB
       / Option+Scrub+Increase+JogWheel           Reaper _WOL_SETSELENVHMAX                                                        // SWS/wol: Set selected envelope height to maximum
        Option+Scrub+Increase+JogWheel           Reaper  41180                                                                    // Envelopes: Move selected points up   1DB
          
          
                     
                                                          
                                                  // MOVE SELECTED POINT    Up/Down 0.2DB          
                                                                                               
                                                          
  /Shift+Option+Zoom+Control+Decrease+JogWheel    Reaper _WOL_SETSELENVHMAX                                                        // SWS/wol: Set selected envelope height to maximum 
  Shift+Option+Zoom+Control+Decrease+JogWheel    Reaper  42382                                                                    // Envelopes: Move selected points down 0.2DB
