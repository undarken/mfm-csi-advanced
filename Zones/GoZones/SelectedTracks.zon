          /Shift+Option+Flip        LearnFocusedFX 
          
    /             RotaryPush|       ToggleChannel
    /    Toggle+DisplayUpper|       FixedTextDisplay ".WIDTH "                                            // TEXT  WIDTH
	/	 Toggle+DisplayLower|       TrackPanAutoRightDisplay                                              // WIDTH NUMERICAL
    /          Toggle+Rotary|       TrackPanAutoRight RingStyle=Dot                                       // WIDTH / PAN SELECTION     
           
           NO Modifiers:

                      Fader|       TrackVolume
                    VUMeter|       TrackOutputMeterMaxPeakLR
                     Rotary|       TrackPanAutoLeft RingStyle=Dot	                                     // PAN	NUMERICAL
                 RotaryPush|       TrackPanAutoLeft RingStyle=Dot	           [ 0.5 ]                   // SET PAN TO CENTRE    : RESETS TRACK PAN 
            Hold+RotaryPush|       TrackVolume	                               [ 0.75 ]                  // SET VOLUME TO 0.0    : RESETS TRACK VOLUME
                    
               DisplayUpper|       TrackNameDisplay                                                      // TEXT NAME
               DisplayLower|       TrackPanAutoLeftDisplay                                               // TEXT PAN                                      
         Touch+DisplayLower|       TrackVolumeDisplay                                                    // VOLUME
         
         
         //SHIFT Modifier = PAN
                                
         Shift+DisplayUpper|       FixedTextDisplay "..PAN"                                              // TEXT PAN  
         Shift+DisplayLower|       TrackPanAutoLeftDisplay                                               // PAN PARAMETER
                Shift+Fader|       TrackPanAutoLeft RingStyle=Dot	                                     // PAN	NUMERICAL   
               Shift+Rotary|       TrackPanAutoLeft RingStyle=Dot	                                     // PAN	NUMERICAL
                                          
           Shift+RotaryPush|       TrackPanAutoLeft RingStyle=Dot [ 0.0 0.5 1.0 ]  				    	  // PAN L  C  R
             
        Option+DisplayUpper|       FixedTextDisplay ".WIDTH "                                            // TEXT  WIDTH        
        Option+DisplayLower|       TrackPanAutoRightDisplay                                              // WIDTH NUMERICAL 
               Option+Fader|       TrackPanAutoRight RingStyle=Dot                                       // WIDTH NUMERICAL
              Option+Rotary|       TrackPanAutoRight RingStyle=Dot                                       // WIDTH NUMERICAL 
                            
          Option+RotaryPush|       TrackPanAutoRight RingStyle=Dot [ 0.0 0.5 1.0 ]                       // WIDTH -100  M  +100     
                                                
